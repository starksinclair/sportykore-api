# Docker dev (docker-compose.dev.yml) — copy to .env.dev
# Run: npm run dev  (uses --env-file .env.dev)

TZ=UTC
NODE_ENV=development
HOST=0.0.0.0
PORT=3333

LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333

SESSION_DRIVER=cookie
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MOBILE_OAUTH_DEEP_LINK=
MOBILE_APP_URL=sportykore://

DRIVE_DISK=fs

DB_CONNECTION=pg
DB_HOST=postgres
DB_PORT=5432
DB_USER=sportykore
DB_PASSWORD=herbBoss
DB_DATABASE=sportykore_dev
DB_SSL=false

# Mail (Resend recommended for dev)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=app@notifications.sportykore.com
MAIL_FROM_NAME=Sportykore
RESEND_API_KEY=

# Redis — bundled in docker-compose.dev.yml (service name: redis)
LIMITER_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
