<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>
      Sportykore
    </title>
  </head>
  <body
    style="margin:0;padding:0;background-color:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,sans-serif;-webkit-font-smoothing:antialiased;"
  >

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
      <tr>
        <td align="center" style="padding:48px 16px;">
          <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;">

            {{-- Header --}}
            <tr>
              <td
                style="background-color:#4A148C;border-radius:14px 14px 0 0;padding:28px 40px;text-align:center;"
              >
                <span
                  style="display:inline-block;font-size:13px;font-weight:700;color:#22c55e;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;"
                >The League Platform</span>
                <br />
                <span style="font-size:30px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;">Sportykore</span>
              </td>
            </tr>

            {{-- Body --}}
            <tr>
              <td
                style="background-color:#ffffff;padding:44px 48px 36px;border-left:1px solid #e2e8f0;border-right:1px solid #e2e8f0;"
              >
                {{{ await $slots.content() }}}
              </td>
            </tr>

            {{-- Footer --}}
            <tr>
              <td
                style="background-color:#f8fafc;border:1px solid #e2e8f0;border-top:none;border-radius:0 0 14px 14px;padding:24px 48px;text-align:center;"
              >
                <p style="margin:0 0 6px;color:#94a3b8;font-size:12px;line-height:1.6;">
                  &copy; {{ new Date().getFullYear() }} Sportykore. All rights reserved.
                </p>
                <p style="margin:0;color:#cbd5e1;font-size:11px;">
                  You received this email because you have an account with Sportykore.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>

  </body>
</html>
