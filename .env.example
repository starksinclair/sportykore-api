# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Optional: mobile deep link after Google OAuth (e.g. kpakore://auth/callback).
# If empty, /api/v1/auth/google/callback returns JSON with the bearer token instead.
MOBILE_OAUTH_DEEP_LINK=
DRIVE_DISK=s3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=

# Mail (Amazon SES — reuses AWS credentials above)
MAIL_FROM_ADDRESS=app@yourdomain.com
MAIL_FROM_NAME=Your name

# Mobile app deep link base URL (e.g. exp://192.168.1.1:8081 in dev, sportykore:// in prod)
MOBILE_APP_URL=
MAIL_MAILER=ses