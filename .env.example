# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=cookie
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Optional: mobile deep link after Google OAuth (e.g. sportykore://auth/callback).
# If empty, /api/v1/auth/google/callback returns JSON with the bearer token instead.
MOBILE_OAUTH_DEEP_LINK=

# ── File storage (Adonis Drive) ─────────────────────────────
# fs = local storage/ + /uploads (default for local dev & Docker)
# s3 = Amazon S3
# gcs = Google Cloud Storage (GCP prod / Cloud Run)
DRIVE_DISK=fs

# S3 (when DRIVE_DISK=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# GCS (when DRIVE_DISK=gcs — Cloud Run uses ADC; omit GCS_KEY)
# GCS_BUCKET=your-project-uploads
# GCS_KEY=file://gcs_key.json

# ── Database ────────────────────────────────────────────────
# sqlite = local file (tmp/db.sqlite3). pg = Postgres (Docker dev / Neon prod).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=sportykore
# DB_PASSWORD=
# DB_DATABASE=sportykore_dev
# DB_SSL=false

# Mail (Amazon SES — uses AWS credentials when configured)
MAIL_MAILER=ses
MAIL_FROM_ADDRESS=app@yourdomain.com
MAIL_FROM_NAME=Your name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Mobile app deep link base URL (e.g. exp://192.168.1.1:8081 in dev, sportykore:// in prod)
MOBILE_APP_URL=
