# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=cookie

# Google OAuth (optional — mobile OAuth routes are currently disabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MOBILE_OAUTH_DEEP_LINK=

# ── File storage (Adonis Drive) ─────────────────────────────
# fs = local storage/ + /uploads (default for local dev)
# s3 = Amazon S3
# gcs = Google Cloud Storage (GCP prod / Cloud Run)
DRIVE_DISK=fs

# S3 (when DRIVE_DISK=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# GCS (when DRIVE_DISK=gcs — Cloud Run uses ADC; omit GCS_KEY)
# GCS_BUCKET=your-project-uploads
# GCS_KEY=file://gcs_key.json

# ── Database ────────────────────────────────────────────────
# sqlite = local file (tmp/db.sqlite3). pg = Postgres (Docker dev / Neon prod).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=sportykore
# DB_PASSWORD=
# DB_DATABASE=sportykore_dev
# DB_SSL=false

# Mail — resend (default) or ses
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=app@yourdomain.com
MAIL_FROM_NAME=Sportykore
RESEND_API_KEY=
# SES (when MAIL_MAILER=ses)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Mobile app deep link base URL (e.g. sportykore:// in prod)
MOBILE_APP_URL=

# Rate limiting + Transmit SSE backplane
# memory = in-process (single instance). redis = required for multi-instance prod.
LIMITER_STORE=memory
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
