# Cloud Run production — copy to .env.prod for local prod-image smoke tests,
# or set these as Cloud Run environment variables (GCS uses ADC; no GCS_KEY).
# Deploy: build Dockerfile production target; migrations run on container start.

# Node (Cloud Run sets PORT=8080 automatically)
TZ=UTC
NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=https://your-service-xxxxx.run.app

# Session
SESSION_DRIVER=cookie

# Google OAuth (optional — routes currently disabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MOBILE_OAUTH_DEEP_LINK=sportykore://auth/callback
MOBILE_APP_URL=sportykore://

# File storage — GCS via Cloud Run service account (omit GCS_KEY)
DRIVE_DISK=gcs
GCS_BUCKET=your-gcs-bucket

# Database (Neon / managed Postgres)
DB_CONNECTION=pg
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=true

# Mail — resend or ses (MAIL_MAILER selects the active mailer in config/mail.ts)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=app@notifications.sportykore.com
MAIL_FROM_NAME=Sportykore
RESEND_API_KEY=
# SES (when MAIL_MAILER=ses)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Redis (Upstash) — rate limiting + Transmit SSE backplane across Cloud Run instances
LIMITER_STORE=redis
REDIS_HOST=your-upstash-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=true
